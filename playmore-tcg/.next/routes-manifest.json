      "regex": "^/admin/products/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/products/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
